# Environment configuration for the Assignment-7 project

# The NODE_ENV variable is commonly set by the runtime (e.g. "development" or "production").
# You can override it here for local development.
NODE_ENV=development

# Development database settings (SQLite for this simple app)
DEV_DB_DIALECT=sqlite
DEV_DB_STORAGE=./database/dev.sqlite
# A URL-style connection string can also be used by Sequelize:
DEV_DATABASE_URL=sqlite:./database/dev.sqlite

# Production database settings (change values or use real service in prod)
# NODE_ENV will normally be set to "production" by your hosting environment.
PROD_DB_DIALECT=sqlite
PROD_DB_STORAGE=./database/prod.sqlite
PROD_DATABASE_URL=sqlite:./database/prod.sqlite
