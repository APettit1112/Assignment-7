# Environment configuration for the Assignment-7 project

# The NODE_ENV variable is commonly set by the runtime (e.g. "development" or "production").
# You can override it here for local development.
NODE_ENV=development

# Development database settings (SQLite for this simple app)
# by default we use a file named "music_library.db" in the database folder;
# Sequelize will create the file if it doesn't already exist when you sync.
DEV_DB_DIALECT=sqlite
DEV_DB_STORAGE=./database/music_library.db
# A URL-style connection string can also be used by Sequelize:
DEV_DATABASE_URL=sqlite:./database/music_library.db

# Production database settings (change values or use real service in prod)
# in this simple example we reuse the same file name but you can point to a
# different location or to a hosted database in a real deployment.
PROD_DB_DIALECT=sqlite
PROD_DB_STORAGE=./database/music_library.db
PROD_DATABASE_URL=sqlite:./database/music_library.db
